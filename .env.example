KISMART_PORT=8787
KISMART_SHOP_NAME=KISMART Global
KISMART_ADMIN_EMAIL=admin@kismart.local
KISMART_ADMIN_PASSWORD=change-this-admin-password
KISMART_SESSION_SECRET=change-this-long-random-session-secret
KISMART_CALLBACK_SECRET=change-this-before-production
KISMART_DEVICE_SYNC_SECRET=4321
# Public HTTPS origin advertised to phones so control works off the shop Wi-Fi.
# Example: https://kismartsystem.vercel.app
KISMART_PUBLIC_BASE_URL=https://kismartsystem.vercel.app
KISMART_PAYMENT_APP_PACKAGES=com.safaricom.mpesa,com.safaricom.mpesa.lifestyle,ke.co.safaricom.mpesa

# Storage: keep "json" for local fallback, switch to "firestore" when Firebase credentials are ready.
KISMART_STORAGE=json

# Firebase / Firestore backend persistence
FIREBASE_PROJECT_ID=kismart-456ee
KISMART_FIRESTORE_DATABASE=default
KISMART_FIRESTORE_SETTINGS_COLLECTION=settings
KISMART_FIRESTORE_SETTINGS_DOCUMENT=main
KISMART_FIRESTORE_CONTRACTS_COLLECTION=contracts
KISMART_FIRESTORE_INVENTORY_DEVICES_COLLECTION=inventoryDevices
KISMART_FIRESTORE_INTAKES_COLLECTION=intakes
KISMART_FIRESTORE_NOTIFICATIONS_COLLECTION=notifications
KISMART_FIRESTORE_SYNC_EVENTS_COLLECTION=syncEvents
KISMART_FIRESTORE_DEVICE_EVENTS_COLLECTION=deviceEvents
KISMART_FIRESTORE_AUDIT_COLLECTION=audit

# Phone SMS delivery.
# Use "simulate" for local testing, "webhook" for any SMS gateway endpoint, or "africas-talking" for Africa's Talking.
KISMART_SMS_PROVIDER=simulate
KISMART_SMS_DEFAULT_COUNTRY_CODE=254
KISMART_SMS_SENDER=KISMART

# Generic SMS webhook mode. The backend POSTs JSON: { to, message, sender, contractId, customerName, noticeId, noticeType }.
# KISMART_SMS_PROVIDER=webhook
# KISMART_SMS_WEBHOOK_URL=https://your-sms-provider.example/send
# KISMART_SMS_WEBHOOK_TOKEN=change-this-provider-token

# Africa's Talking mode.
# KISMART_SMS_PROVIDER=africas-talking
# AFRICASTALKING_USERNAME=your_username
# AFRICASTALKING_API_KEY=your_api_key
# AFRICASTALKING_ENV=production
# AFRICASTALKING_SENDER_ID=KISMART

# iOS / Apple MDM control bridge.
# Use "simulate" for local testing, or "webhook" to send command payloads to your Apple MDM provider.
KISMART_IOS_MDM_PROVIDER=simulate
# KISMART_IOS_MDM_PROVIDER=webhook
# KISMART_IOS_MDM_WEBHOOK_URL=https://your-mdm-provider.example/kismart/commands
# KISMART_IOS_MDM_WEBHOOK_TOKEN=change-this-mdm-token

# Use ONE of these credential options for Firestore mode.
# Recommended local option: download a Firebase Admin service-account JSON file and point to it here.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Alternative for hosted environments: paste the full service-account JSON into an env var.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"kismart-456ee",...}
